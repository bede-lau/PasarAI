# Public API origin used by the Next.js server for contract-backed dashboard data.
PASARAI_API_BASE_URL=
PASARAI_API_BEARER_TOKEN=<PLACEHOLDER>
PASARAI_DASHBOARD_DATE=

# Development only. Production builds reject a value of 1.
PASARAI_SYNTHETIC_PREVIEW=1

# Set to 0 only for a trusted demo that should open without a login screen.
# Authentication remains required by default when this variable is omitted.
PASARAI_WEB_AUTH_REQUIRED=1
PASARAI_WEB_SESSION_SECRET=<PLACEHOLDER>
PASARAI_WEB_ACCESS_CODE=<PLACEHOLDER>

# Merchant identity used by authenticated or trusted demo deployments.
PASARAI_MERCHANT_ID=
PASARAI_MERCHANT_NAME=
PASARAI_MERCHANT_LOCATION=
PASARAI_PRODUCT_ID=
PASARAI_PRODUCT_NAME=
