{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "costs.response",
  "x-typescript-name": "CostsResponse",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "event_id"],
      "properties": {
        "state": { "const": "committed" },
        "event_id": { "$ref": "../shared/primitives.schema.json#/$defs/Identifier" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "clarifications"],
      "properties": {
        "state": { "const": "clarification_required" },
        "clarifications": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../shared/primitives.schema.json#/$defs/Ambiguity" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "errors"],
      "properties": {
        "state": { "const": "rejected" },
        "errors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../shared/primitives.schema.json#/$defs/ContractError" }
        }
      }
    }
  ]
}
