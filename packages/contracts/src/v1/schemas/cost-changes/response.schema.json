{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cost-changes.response",
  "x-typescript-name": "CostChangeResponse",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "event_id", "before_value_rm", "after_value_rm"],
      "properties": {
        "state": { "const": "committed" },
        "event_id": { "$ref": "../shared/primitives.schema.json#/$defs/Identifier" },
        "before_value_rm": { "$ref": "../shared/primitives.schema.json#/$defs/NonNegativeMyrAmount" },
        "after_value_rm": { "$ref": "../shared/primitives.schema.json#/$defs/NonNegativeMyrAmount" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "clarification_source", "clarifications"],
      "properties": {
        "state": { "const": "clarification_required" },
        "clarification_source": { "$ref": "../shared/primitives.schema.json#/$defs/Identifier" },
        "clarifications": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../shared/primitives.schema.json#/$defs/Ambiguity" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "errors"],
      "properties": {
        "state": { "const": "rejected" },
        "errors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../shared/primitives.schema.json#/$defs/ContractError" }
        }
      }
    }
  ]
}
