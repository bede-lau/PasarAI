{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "analytics-day-status.response",
  "x-typescript-name": "AnalyticsDayStatusResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state",
    "event_id",
    "date",
    "business_day_state",
    "sold_out_state"
  ],
  "properties": {
    "state": {
      "const": "committed"
    },
    "event_id": {
      "$ref": "../shared/primitives.schema.json#/$defs/Identifier"
    },
    "date": {
      "$ref": "../shared/primitives.schema.json#/$defs/Date"
    },
    "business_day_state": {
      "enum": [
        "closed_complete",
        "closed_no_sales"
      ]
    },
    "sold_out_state": {
      "enum": [
        "yes",
        "no",
        "unknown"
      ]
    }
  }
}
