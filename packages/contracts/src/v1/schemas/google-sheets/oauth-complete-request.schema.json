{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "google-sheets-oauth-complete.request",
  "x-typescript-name": "GoogleSheetsOAuthCompleteRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "state", "redirect_uri"],
  "properties": {
    "code": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "minLength": 32
    },
    "redirect_uri": {
      "type": "string",
      "format": "uri"
    }
  }
}
